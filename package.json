{
  "name": "blorp",
  "version": "1.12.4",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "husky",
    "dev": "vite dev",
    "preview": "vite preview",
    "dev:tauri": "tauri dev",
    "dev:ios": "ionic capacitor run ios -l --external",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "vite build && cap sync && pnpm cp-package-json",
    "build:tauri": "tauri build",
    "build:docker": "docker build . --tag blorp",
    "beta:ios": "dotenvx run -- ./scripts/beta-ios.sh",
    "beta:android": "dotenvx run -- ./scripts/beta-android.sh",
    "cp-package-json": "cp ./package.json ./dist/package.json",
    "test": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --watch --coverage --ui",
    "test:e2e": "playwright test",
    "test:ts": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --stats-json",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:visual:update": "playwright test --config playwright.visual.config.ts --update-snapshots"
  },
