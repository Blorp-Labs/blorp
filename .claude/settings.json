{
  "permissions": {
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(* | bash)",
      "Bash(* | sh)",
      "Bash(*|bash)",
      "Bash(*|sh)",
      "Bash(eval *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Bash(source *)",
      "Bash(. *)",
      "Bash(npx *)",
      "Bash(pnpx *)",
      "Bash(pnpm dlx *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)"
    ],
    "allow": [
      "Bash(pnpm run test)",
      "Bash(pnpm run test:ts)",
      "Bash(pnpm run lint)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/prettier-hook.js"
          }
        ]
      }
    ]
  }
}
